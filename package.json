{
  "name": "@supaflow/cli",
  "version": "0.1.0",
  "description": "CLI for Supaflow data integration platform",
  "type": "module",
  "bin": {
    "supaflow": "./bin/supaflow.mjs"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": ["supaflow", "cli", "data-integration", "pipeline"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/supaflow-labs/supaflow-cli.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
